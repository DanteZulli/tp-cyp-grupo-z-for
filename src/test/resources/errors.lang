// Variable no declarada
x = 5;

// Redeclaracion
variable a : entero = 1;
variable a : entero = 2;

// Error de tipo en declaracion
variable b : entero = "texto";

// Error de tipo en asignacion
variable c : entero = 0;
c = verdad;

// Operacion invalida: suma de texto y entero
variable d : texto = "a" + 1;

// Division por cero literal
variable e : entero = 10 / 0;

// Operador relacional invalido con texto
variable f : boleano = "hola" < "mundo";

// no sobre entero
variable g : boleano = no 42;

// si con condicion no bool
si (42) {
    mostrar("si");
}

// Para con condicion no bool
para (variable i : entero = 0; i + 1; i = i + 1) {
    mostrar(i);
}

// Para con error de tipo en la declaracion
para (variable j : entero = "texto"; j < 5; j = j + 1) {
    mostrar(j);
}

// Para con error de tipo en el update
para (variable k : entero = 0; k < 5; k = verdad) {
    mostrar(k);
}
