// Variable no declarada
x = 5;

// Redeclaracion
var a : int = 1;
var a : int = 2;

// Error de tipo en declaracion
var b : int = "texto";

// Error de tipo en asignacion
var c : int = 0;
c = true;

// Operacion invalida: suma de string e int
var d : string = "a" + 1;

// Division por cero literal
var e : int = 10 / 0;

// Operador relacional invalido con string
var f : bool = "hola" < "mundo";

// ! sobre entero
var g : bool = !42;

// if con condicion no bool
if (42) {
    print("si");
}

// For con condicion no bool
for (var i : int = 0; i + 1; i = i + 1) {
    print(i);
}

// For con error de tipo en la declaracion
for (var j : int = "texto"; j < 5; j = j + 1) {
    print(j);
}

// For con error de tipo en el update
for (var k : int = 0; k < 5; k = true) {
    print(k);
}