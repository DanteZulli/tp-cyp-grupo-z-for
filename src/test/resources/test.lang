// ── Tipos de datos y variables ──
variable num : entero = 42;
variable precio : real = 3.14;
variable nombre : texto = "hola";
variable ok : boleano = verdad;
variable sinInit : entero;

// ── Asignacion ──
sinInit = 10;

// ── Expresiones aritmeticas ──
variable suma : entero = num + 5;
variable resta : entero = num - 2;
variable mult : entero = num * 2;
variable div : real = precio / 2.0;
variable negativo : entero = -num;

// ── Expresiones relacionales ──
variable igual : boleano = num == 42;
variable distinto : boleano = num != 0;
variable menor : boleano = num < 50;
variable mayor : boleano = num > 10;
variable menorIgual : boleano = num <= 42;
variable mayorIgual : boleano = num >= 42;

// ── Expresiones logicas ──
variable yLogico : boleano = ok y verdad;
variable oLogico : boleano = ok o falso;
variable noLogico : boleano = no ok;

// ── Mostrar ──
mostrar("Entero:");
mostrar(num);
mostrar("Real:");
mostrar(precio);
mostrar("Texto:");
mostrar(nombre);
mostrar("Bool:");
mostrar(ok);

// ── Si-sino ──
mostrar("--- si-sino ---");
si (num >= 18) {
    mostrar("Mayor de edad");
} sino {
    mostrar("Menor de edad");
}

// ── Si-sino anidado ──
mostrar("--- si-sino anidado ---");
si (num > 0) {
    si (num > 100) {
        mostrar("Grande");
    } sino {
        mostrar("Chico positivo");
    }
} sino {
    mostrar("Negativo o cero");
}

// ── Si sin sino ──
mostrar("--- si sin sino ---");
si (num == 42) {
    mostrar("Es la respuesta");
}

mostrar("--- FIN ---");

// ── Para basico ──
mostrar("--- para basico ---");
para (variable i : entero = 0; i < 5; i = i + 1) {
    mostrar(i);
}

// ── Para con cuerpo que usa la variable ──
mostrar("--- para con expresion ---");
para (variable j : entero = 1; j < 4; j = j + 1) {
    mostrar(j * 2);
}

// ── Para que no ejecuta (condicion falsa desde el inicio) ──
mostrar("--- para sin iteraciones ---");
para (variable k : entero = 10; k < 5; k = k + 1) {
    mostrar(k);
}
mostrar("despues del para vacio");

// ── Para con si adentro ──
mostrar("--- para con si adentro ---");
para (variable n : entero = 0; n < 6; n = n + 1) {
    si (n == 3) {
        mostrar("encontre el 3");
    }
}

// ── Para anidado ──
mostrar("--- para anidado ---");
para (variable p : entero = 0; p < 3; p = p + 1) {
    para (variable q : entero = 0; q < 3; q = q + 1) {
        mostrar(p + q);
    }
}

mostrar("--- FIN PARA ---");
