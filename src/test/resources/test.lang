// ── Tipos de datos y variables ──
var entero : int = 42;
var real : float = 3.14;
var texto : string = "hola";
var flag : bool = true;
var sinInit : int;

// ── Asignacion ──
sinInit = 10;

// ── Expresiones aritmeticas ──
var suma : int = entero + 5;
var resta : int = entero - 2;
var mult : int = entero * 2;
var div : float = real / 2.0;
var negativo : int = -entero;

// ── Expresiones relacionales ──
var igual : bool = entero == 42;
var distinto : bool = entero != 0;
var menor : bool = entero < 50;
var mayor : bool = entero > 10;
var menorIgual : bool = entero <= 42;
var mayorIgual : bool = entero >= 42;

// ── Expresiones logicas ──
var yLogico : bool = flag && true;
var oLogico : bool = flag || false;
var noLogico : bool = !flag;

// ── Print ──
print("Entero:");
print(entero);
print("Real:");
print(real);
print("Texto:");
print(texto);
print("Bool:");
print(flag);

// ── If-else ──
print("--- if-else ---");
if (entero >= 18) {
    print("Mayor de edad");
} else {
    print("Menor de edad");
}

// ── If-else anidado ──
print("--- if-else anidado ---");
if (entero > 0) {
    if (entero > 100) {
        print("Grande");
    } else {
        print("Chico positivo");
    }
} else {
    print("Negativo o cero");
}

// ── If sin else ──
print("--- if sin else ---");
if (entero == 42) {
    print("Es la respuesta");
}

print("--- FIN ---");

// ── For basico ──
print("--- for basico ---");
for (var i : int = 0; i < 5; i = i + 1) {
    print(i);
}

// ── For con cuerpo que usa la variable ──
print("--- for con expresion ---");
for (var j : int = 1; j < 4; j = j + 1) {
    print(j * 2);
}

// ── For que no ejecuta (condicion falsa desde el inicio) ──
print("--- for sin iteraciones ---");
for (var k : int = 10; k < 5; k = k + 1) {
    print(k);
}
print("despues del for vacio");

// ── For con if adentro ──
print("--- for con if adentro ---");
for (var n : int = 0; n < 6; n = n + 1) {
    if (n == 3) {
        print("encontre el 3");
    }
}

// ── For anidado ──
print("--- for anidado ---");
for (var x : int = 0; x < 3; x = x + 1) {
    for (var y : int = 0; y < 3; y = y + 1) {
        print(x + y);
    }
}

print("--- FIN FOR ---");
